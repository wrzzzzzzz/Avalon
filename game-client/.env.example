REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000

# WebRTC voice configuration.
# The client first tries GET /api/voice/ice from the server.
# These client values are only a fallback for development.
REACT_APP_STUN_URLS=stun:stun.l.google.com:19302

# TURN is required for stable public internet voice when players are behind strict NATs.
# Example:
# REACT_APP_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# REACT_APP_TURN_USERNAME=avalon
# REACT_APP_TURN_CREDENTIAL=change-this-password

# Set to true if you want all voice traffic to relay through TURN.
# This is more stable, but consumes server bandwidth.
REACT_APP_FORCE_TURN=false

# Advanced alternative: provide raw JSON instead of split vars above.
# REACT_APP_RTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"avalon","credential":"change-this-password"}]
