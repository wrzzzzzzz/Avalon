PORT=5000
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/game-db
JWT_SECRET=change-this-secret
NODE_ENV=development

# WebRTC voice configuration returned by GET /api/voice/ice.
RTC_STUN_URLS=stun:stun.l.google.com:19302

# TURN is required for stable public internet voice.
# RTC_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# RTC_TURN_USERNAME=avalon
# RTC_TURN_CREDENTIAL=change-this-password

# Set to true to force all voice traffic through TURN.
RTC_FORCE_TURN=false

# Advanced alternative: raw JSON ICE servers.
# RTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478"],"username":"avalon","credential":"change-this-password"}]
